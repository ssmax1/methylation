###############################################
# BISCUIT WGBS PIPELINE CONFIGURATION
###############################################

# --- Project Paths ---
WDIR=/path/to/project
RAWDATA=$WDIR/raw_fastq/wgbs
REFDIR=$WDIR/refgenome
BISCDIR=$REFDIR/biscuit
DATA_DIR=$WDIR/WGBS
FQMGDIR=$RAWDATA/merged
TLOGDIR=$FQMGDIR/TLOG

# --- Reference Genome ---
REF_GENOME_URL="http://ftp.ensembl.org/pub/release-104/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna_sm.primary_assembly.fa.gz"
REF_GTF_URL="http://ftp.ensembl.org/pub/release-104/gtf/homo_sapiens/Homo_sapiens.GRCh38.104.gtf.gz"

# --- Adapter File ---
TRIM=$REFDIR/adapter_trim.fa.txt

# --- SLURM Email Notifications ---
EMAIL=user@example.com

# --- Software Locations (if not using modules) ---
BISCUIT_BIN=/path/to/biscuit
SAMBLASTER_BIN=/path/to/samblaster
SAMTOOLS_BIN=samtools
SKEWER_BIN=skewer
PIGZ_BIN=pigz
PARALLEL_BIN=parallel
BEDTOOLS_BIN=bedtools
TABIX_BIN=tabix
BGZIP_BIN=bgzip

# --- CPU & Memory Defaults ---
THREADS=36
MEMORY=150000
